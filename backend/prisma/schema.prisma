generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  passwordHash        String
  subscriptionStatus  SubscriptionStatus @default(FREE)
  subscriptionEndDate DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  documents           Document[]
  orders              Order[]
  usageLogs           UsageLog[]
}

model UsageLog {
  id         String   @id @default(uuid())
  userId     String
  actionType String
  presetUsed String
  tokenUsage Int?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Order {
  id        String      @id
  userId    String
  amount    Decimal     @db.Decimal(10, 2)
  currency  String
  planType  String
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Document {
  id         String   @id @default(uuid())
  userId     String
  title      String
  content    String
  wordCount  Int?
  preset     String
  createdAt  DateTime @default(now())
  shareToken String?  @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  FREE
  PLUS
  PRO
  ULTRA
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDING
  REFUNDED
}
