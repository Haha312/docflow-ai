# 数据库配置 (SQLite 本地文件)
DATABASE_URL="file:./dev.db"

# Google Gemini API Key (从前端 .env.local 复制)
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro-preview

# DeepSeek (可选,使用 DeepSeek V4 旗舰模型)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# 字节豆包 (可选)
DOUBAO_API_KEY=
DOUBAO_ENDPOINT_ID=

# 阿里通义千问 (可选)
DASHSCOPE_API_KEY=

# JWT 密钥 (随机生成,用于签名 token,至少 32 字符)
JWT_SECRET=your_random_secret_here_min_32_chars

# 管理员邮箱 (逗号分隔),也可在数据库 SystemConfig.ADMIN_EMAILS 覆盖
ADMIN_EMAILS=

# Stripe 配置 (可选,暂时留空)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 支付宝配置 (可选,暂时留空)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 服务器配置
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# 前端地址 (用于 CORS)
FRONTEND_URL=http://localhost:5173
