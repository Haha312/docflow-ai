# ============ 数据库 (Supabase PostgreSQL) ============
# 从 Supabase Dashboard → Project Settings → Database → Connection string → URI
# 使用 "Direct connection" (端口 5432),把 [YOUR-PASSWORD] 替换为你设置的数据库密码
# 建议追加连接参数:?connect_timeout=15&pool_timeout=15&sslmode=require
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require"

# ============ AI 模型 (按需选填,至少配 1 个就能用对应模型) ============

# --- Gemini Flash + Gemini 3 Pro ---
# 官方 key: https://aistudio.google.com/apikey (国内需代理)
# 也可以填代理服务的 key (如 deepbricks / openrouter 等 OpenAI 兼容网关)
GOOGLE_API_KEY=your_gemini_api_key_here
# 用 Pro 时的模型 ID (默认 gemini-3-pro-preview)
GEMINI_MODEL=gemini-3-pro-preview
# 国内访问需要配代理网关 (OpenAI 兼容路径,如 https://your-proxy.com/v1beta/openai)
# 海外或自己有梯子留空即可
GEMINI_OPENAI_BASE_URL=

# --- 豆包 Doubao (火山引擎方舟) ---
# 控制台: https://console.volcengine.com/ark
# 注意:DOUBAO_ENDPOINT_ID 是你在"在线推理"创建的接入点 ID (ep-xxx),不是模型名
DOUBAO_API_KEY=
DOUBAO_ENDPOINT_ID=

# --- DeepSeek V3.2 ---
# 控制台: https://platform.deepseek.com/api_keys
# 国内直连,新用户送测试 token,推荐先用这个跑通主流程
DEEPSEEK_API_KEY=

# ============ 鉴权 ============
# JWT 密钥 (随机生成,用于签名 token,至少 32 字符)
JWT_SECRET=your_random_secret_here_min_32_chars

# 管理员邮箱列表 (逗号分隔,这些邮箱拥有 admin 权限)
ADMIN_EMAILS=admin@docuflow.ai

# ============ 支付 (可选) ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 支付宝 (可选)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ============ 邮件 SMTP (可选,不配则邮件不真实发送,只在终端打印 [MOCK EMAIL]) ============
# 推荐服务商:Resend / SendGrid / 阿里云邮件推送 / 腾讯企业邮箱 / Mailgun
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DocFlow AI <no-reply@docuflow.ai>"

# ============ Redis (生产必填,dev 留空会用内存 MockRedis,重启后数据清空) ============
# 推荐:Upstash (免费层够 hobby 用) / Railway / 阿里云 Redis
REDIS_URL=

# ============ 服务器 ============
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# 前端地址 (用于 CORS,逗号分隔多个)
FRONTEND_URL=http://localhost:5173
