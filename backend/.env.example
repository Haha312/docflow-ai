# ============================================================
# DocFlow AI 后端环境变量。复制为 backend/.env 并填入真实值。
# 标【生产必填】的变量缺失时,NODE_ENV=production 启动会直接退出(fail-fast)。
# 密钥(支付宝私钥/各 API key)只用本文件注入,严禁提交进 git。
# ============================================================

# ============ 数据库 (Supabase PostgreSQL) 【生产必填】 ============
# Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require"

# ============ AI 模型 ============
# --- Gemini Flash + Gemini 3 Pro ---
AI_PROVIDER=deepseek
AI_MAX_TOKENS=8192
AI_TIMEOUT_MS=240000
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro-preview
# 国内访问需配代理网关 (OpenAI 兼容路径);海外留空
GEMINI_OPENAI_BASE_URL=
# --- 豆包 Doubao (火山引擎方舟) ---
DOUBAO_API_KEY=
DOUBAO_ENDPOINT_ID=
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_API_KEY=
VISION_MODEL=doubao-seed-2-0-pro-260215
# --- DeepSeek (默认 deepseek-v4-flash,deepseek-chat 已停用) ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# ============ 鉴权 ============
# JWT 密钥 (随机生成,至少 32 字符) 【生产必填】
JWT_SECRET=your_random_secret_here_min_32_chars
# 管理员手机号列表 (逗号分隔,这些手机号拥有 admin 权限)
ADMIN_PHONES=13800138000

# ============ 短信验证码登录 (腾讯云短信) 【生产必填:手机登录核心】 ============
# 控制台: https://console.cloud.tencent.com/smsv2  访问密钥: https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou

# ============ 支付:微信支付 V3 Native 【生产必填】 ============
# 新订单只走微信官方动态二维码;固定收款码/支付宝入口已停用。
WXPAY_MCHID=
WXPAY_APPID=
WXPAY_CERT_SERIAL=
WXPAY_APIV3_KEY=
WXPAY_PRIVATE_KEY_PATH=
WXPAY_PUBLIC_KEY_PATH=
WXPAY_PUBLIC_KEY_ID=
# 可选:不填则用 BACKEND_URL/PUBLIC_URL + /api/payment/webhook/wechat
WXPAY_NOTIFY_URL=

# ============ 邮件 SMTP (选填:仅用于支付收据/续费提醒;手机登录不依赖邮件) ============
# 配了才会真实发信;生产未配则相关通知静默跳过(记 error)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DocFlow AI <no-reply@docuflow.ai>"

# ============ Redis (选填;留空则生产也用内存版 MockRedis,进程重启会清空) ============
# 团队评估后接受该风险:重启窗口内重复的微信支付回调可能被当新单重复处理,验证码/封号状态也会清空。
# 若要配:腾讯云服务器上装 redis-server 最省事(sudo apt install redis-server),或用云托管版。
REDIS_URL=

# ============ 服务器 ============
PORT=3001
NODE_ENV=development
# 后端公网地址 (支付回调默认据此拼接) 【生产必填】
BACKEND_URL=http://localhost:3001
# 反代层数 (nginx 单层=1);决定 req.ip 取 X-Forwarded-For 哪一跳,影响限流防伪造
TRUST_PROXY_HOPS=1

# ============ CORS 【生产必填:配 CORS_ORIGINS 或 FRONTEND_URL 之一】 ============
# 允许的前端来源 (逗号分隔多个);生产不配会拒绝所有跨域请求
CORS_ORIGINS=
FRONTEND_URL=http://localhost:5173

# ============ 其它 (选填) ============
# 已配 HTTPS 反代后再设为 true 开启 HSTS;否则会把用户锁死在 https
ENABLE_HSTS=
# 并发生成上限 (默认 50)
MAX_CONCURRENT_GENERATIONS=50
# Gemini 国内代理 (默认 http://127.0.0.1:10809),生产用云上直连可留空
HTTPS_PROXY=
