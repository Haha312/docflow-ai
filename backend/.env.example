# ============ 数据库 (Supabase PostgreSQL) ============
# 从 Supabase Dashboard → Project Settings → Database → Connection string → URI
# 使用 "Direct connection" (端口 5432),把 [YOUR-PASSWORD] 替换为你设置的数据库密码
# 建议追加连接参数:?connect_timeout=15&pool_timeout=15&sslmode=require
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require"

# ============ AI 模型 ============
# Google Gemini API Key (从前端 .env.local 复制)
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro-preview

# ============ 鉴权 ============
# JWT 密钥 (随机生成,用于签名 token,至少 32 字符)
JWT_SECRET=your_random_secret_here_min_32_chars

# 管理员邮箱列表 (逗号分隔,这些邮箱拥有 admin 权限)
ADMIN_EMAILS=admin@docuflow.ai

# ============ 支付 (可选) ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 支付宝 (可选)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ============ 服务器 ============
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# 前端地址 (用于 CORS,逗号分隔多个)
FRONTEND_URL=http://localhost:5173
